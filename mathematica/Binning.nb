Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ChooseWindowSize", "[", 
   RowBox[{"targetFreq_", ",", "sampleRate_", ",", 
    RowBox[{"maxErr_", ":", "10"}], ",", 
    RowBox[{"maxT_", ":", "0.01"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"maxSize", "=", 
       RowBox[{"Round", "[", 
        RowBox[{"maxT", " ", "sampleRate"}], "]"}]}], ",", "err", ",", "bin", 
      ",", "goodq"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"err", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["sampleRate", "q"], 
          RowBox[{"Round", "[", 
           RowBox[{"targetFreq", "/", 
            FractionBox["sampleRate", "q"]}], "]"}]}], "-", "targetFreq"}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "1", ",", "maxSize"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"goodq", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"err", ",", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "#", "]"}], "<=", "maxErr"}], "&"}], 
         "->", "\"\<Index\>\""}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"err", "=", 
      RowBox[{"err", "[", 
       RowBox[{"[", "goodq", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bin", "=", 
      RowBox[{"Round", "[", 
       RowBox[{"targetFreq", "/", 
        FractionBox["sampleRate", "goodq"]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"TableForm", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"goodq", ",", 
          RowBox[{
           RowBox[{"goodq", "/", "sampleRate"}], "//", "N"}], ",", "bin", ",", 
          RowBox[{"err", "//", "N"}], ",", 
          RowBox[{
           RowBox[{
            FractionBox["sampleRate", "goodq"], 
            RowBox[{"(", 
             RowBox[{"bin", "-", "1"}], ")"}]}], "//", "N"}], ",", 
          RowBox[{
           RowBox[{
            FractionBox["sampleRate", "goodq"], "bin"}], "//", "N"}], ",", 
          RowBox[{
           RowBox[{
            FractionBox["sampleRate", "goodq"], 
            RowBox[{"(", 
             RowBox[{"bin", "+", "1"}], ")"}]}], "//", "N"}]}], "}"}], "]"}], 
       ",", 
       RowBox[{"TableHeadings", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"None", ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Window size\>\"", ",", "\"\<T\>\"", 
            ",", "\"\<Central bin n\>\"", ",", "\"\<err\>\"", 
            ",", "\"\<\!\(\*SubscriptBox[\(f\), \(n - 1\)]\)\>\"", 
            ",", "\"\<\!\(\*SubscriptBox[\(f\), \(n + 1\)]\)\>\"", 
            ",", "\"\<\!\(\*SubscriptBox[\(f\), \(n + 1\)]\)\>\""}], "}"}]}], 
