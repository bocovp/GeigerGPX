Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "1.", " ", "Define", " ", "Parameters", " ", "and", " ", "True", " ", 
     "Time"}], "-", 
    RowBox[{"Varying", " ", "Rate"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Tmax", "=", "100"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Total", " ", "time", " ", "window"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"bandwidth", "=", "5"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Scale", " ", "parameter", " ", 
     RowBox[{"(", "h", ")"}], " ", "for", " ", "the", " ", "kernel"}], "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"alpha", "=", "0.05"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"For", " ", "95", "%", " ", "Confidence", " ", "Interval"}], 
    "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"True", " ", "time"}], "-", 
      RowBox[{"varying", " ", "parameter", " ", "lambda", 
       RowBox[{"(", "t", ")"}]}]}], ":", 
     RowBox[{
     "a", " ", "baseline", " ", "with", " ", "a", " ", "sinusoidal", " ", 
      "wave"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"trueLambda", "[", "t_", "]"}], ":=", 
     RowBox[{"0.4", "+", 
      RowBox[{"0.3", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", "*", "Pi", "*", 
         RowBox[{"t", "/", "40"}]}], "]"}]}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Simulate", " ", "the", " ", "Non"}], "-", 
     RowBox[{"Homogeneous", " ", "Poisson", " ", "Process", " ", 
      RowBox[{"(", 
       RowBox[{"Thinning", " ", "Method"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lambdaMax", "=", "8"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Must", " ", "be"}], ">=", 
     RowBox[{"maximum", " ", "of", " ", 
      RowBox[{"trueLambda", "[", "t", "]"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"events", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tCurr", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "43", "]"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"For", " ", "reproducibility"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"While", "[", 
     RowBox[{
      RowBox[{"tCurr", "<", "Tmax"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "Generate", " ", "next", " ", "candidate", " ", "time", " ", "from", " ",
         "a", " ", "homogeneous", " ", "Poisson", " ", "process"}], "*)"}], 
      RowBox[{
       RowBox[{"u1", "=", 
        RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"tCurr", "=", 
        RowBox[{"tCurr", "-", 
         RowBox[{
          RowBox[{"Log", "[", "u1", "]"}], "/", "lambdaMax"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tCurr", "<", "Tmax"}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "Accept", " ", "or", " ", "reject", " ", "based", " ", "on", " ", 
           "the", " ", "true", " ", "rate", " ", "at", " ", "tCurr"}], "*)"}], 
         RowBox[{
          RowBox[{"u2", "=", 
           RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"u2", "<", 
             RowBox[{
              RowBox[{"trueLambda", "[", "tCurr", "]"}], "/", "lambdaMax"}]}],
             ",", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"events", ",", "tCurr"}], "]"}]}], "]"}], ";"}]}], "]"}],
        ";"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "Epanechnikov", " ", "Kernel", " ", 
     "and", " ", "Estimators"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Epanechnikov", " ", "kernel", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"epanechnikov", "[", "u_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "u", "]"}], "<=", "1"}], ",", 
       RowBox[{"0.75", "*", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"u", "^", "2"}]}], ")"}]}], ",", "0"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Instantaneous", " ", "rate", " ", "estimate", " ", 
     RowBox[{"(", 
      RowBox[{"Sum", " ", "of", " ", "weights"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"estLambda", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "bandwidth"}], ")"}], "*", 
        RowBox[{"epanechnikov", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"t", "-", "ti"}], ")"}], "/", "bandwidth"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"ti", ",", "events"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Local", " ", "variance", " ", "of", " ", "the", " ", "estimate", " ", 
     RowBox[{"(", 
      RowBox[{"Sum", " ", "of", " ", "squared", " ", "weights"}], ")"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"varLambda", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "bandwidth"}], ")"}], "*", 
          RowBox[{"epanechnikov", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"t", "-", "ti"}], ")"}], "/", "bandwidth"}], "]"}]}], 
         ")"}], "^", "2"}], ",", 
       RowBox[{"{", 
        RowBox[{"ti", ",", "events"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Calculate", " ", "Asymmetric", " ", "Confidence", " ", 
     "Intervals", " ", 
     RowBox[{"(", 
      RowBox[{"Scaled", " ", "Gamma", " ", "Method"}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"We", " ", "add", " ", "a", " ", "tiny", " ", "epsilon", " ", 
     RowBox[{"(", 
      RowBox[{"10", "^", 
       RowBox[{"-", "10"}]}], ")"}], " ", "to", " ", "avoid", " ", "division",
      " ", "by", " ", "zero", " ", "when", " ", "the", " ", "rate", " ", 
     "drops", " ", "to", " ", "0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lowerCI", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lam", ",", "var", ",", "neff", ",", "scaleFunc"}], "}"}], ",", 
       RowBox[{
        RowBox[{"lam", "=", 
         RowBox[{
          RowBox[{"estLambda", "[", "t", "]"}], "+", 
          RowBox[{"10", "^", 
           RowBox[{"-", "10"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"var", "=", 
         RowBox[{
          RowBox[{"varLambda", "[", "t", "]"}], "+", 
          RowBox[{"10", "^", 
           RowBox[{"-", "10"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"neff", "=", 
         RowBox[{
          RowBox[{"lam", "^", "2"}], "/", "var"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"scaleFunc", "=", 
         RowBox[{"var", "/", "lam"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"InverseCDF", "[", 
            RowBox[{
             RowBox[{"GammaDistribution", "[", 
              RowBox[{"neff", ",", "scaleFunc"}], "]"}], ",", 
             RowBox[{"alpha", "/", "2"}]}], "]"}], ",", "0"}], "]"}]}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"upperCI", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lam", ",", "var", ",", "neff", ",", "scaleFunc"}], "}"}], ",", 
       RowBox[{
        RowBox[{"lam", "=", 
         RowBox[{
          RowBox[{"estLambda", "[", "t", "]"}], "+", 
          RowBox[{"10", "^", 
           RowBox[{"-", "10"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"var", "=", 
         RowBox[{
          RowBox[{"varLambda", "[", "t", "]"}], "+", 
          RowBox[{"10", "^", 
           RowBox[{"-", "10"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"neff", "=", 
         RowBox[{
          RowBox[{"lam", "^", "2"}], "/", "var"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"scaleFunc", "=", 
         RowBox[{"var", "/", "lam"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"InverseCDF", "[", 
            RowBox[{
             RowBox[{"GammaDistribution", "[", 
              RowBox[{
               RowBox[{"neff", "+", "1"}], ",", "scaleFunc"}], "]"}], ",", 
             RowBox[{"1", "-", 
              RowBox[{"alpha", "/", "2"}]}]}], "]"}], ",", "0"}], "]"}]}]}]}],
       "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Plotting", " ", "the", " ", "Results"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"trueLambda", "[", "t", "]"}], ",", 
       RowBox[{"estLambda", "[", "t", "]"}], ",", 
       RowBox[{"lowerCI", "[", "t", "]"}], ",", 
       RowBox[{"upperCI", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "Tmax"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", "Dashed", ",", 
          RowBox[{"Thickness", "[", "0.005", "]"}]}], "]"}], ",", 
        RowBox[{"(*", "True", "*)"}], 
        RowBox[{"Directive", "[", 
         RowBox[{"Blue", ",", "Thick"}], "]"}], ",", 
        RowBox[{"(*", "Estimate", "*)"}], 
        RowBox[{"Directive", "[", 
         RowBox[{"Red", ",", "Dotted"}], "]"}], ",", 
        RowBox[{"(*", 
         RowBox[{"Lower", " ", "CI"}], "*)"}], 
        RowBox[{"Directive", "[", 
         RowBox[{"Red", ",", "Dotted"}], "]"}]}], "                      ", 
       RowBox[{"(*", 
        RowBox[{"Upper", " ", "CI"}], "*)"}], "}"}]}], ",", 
     RowBox[{"Filling", "->", 
      RowBox[{"{", 
       RowBox[{"3", "->", 
        RowBox[{"{", "4", "}"}]}], "}"}]}], ",", 
     RowBox[{"FillingStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Red", ",", 
        RowBox[{"Opacity", "[", "0.15", "]"}]}], "]"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"LineLegend", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<True \[Lambda](t)\>\"", 
           ",", "\"\<Estimated \\!\\(\\*OverscriptBox[\\(\[Lambda]\\), \\(\\^\
\\)]\\)(t)\>\"", ",", "\"\<95% Lower CI\>\"", ",", "\"\<95% Upper CI\>\""}], 
          "}"}], "]"}], ",", "Below"}], "]"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Time (s)\>\"", ",", "\"\<Rate (Events / s)\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Epanechnikov KDE with Scaled Gamma Asymmetric CIs\>\"", ",",
         "Bold", ",", "14"}], "]"}]}], ",", 
