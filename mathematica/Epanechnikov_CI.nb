            RowBox[{
             RowBox[{"ChiSquareDistribution", "[", 
              RowBox[{"2", "*", "nInt"}], "]"}], ",", 
             RowBox[{"alpha", "/", "2"}]}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "Teff"}], ")"}]}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"upperCINoVar", "[", "t_", "]"}], ":=", 
