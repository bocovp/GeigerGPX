             RowBox[{"GammaDistribution", "[", 
              RowBox[{"nEff", ",", "1"}], "]"}], ",", 
             RowBox[{"alpha", "/", "2"}]}], "]"}], "/", "Teff"}]}], "]"}]}]}],
       "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
