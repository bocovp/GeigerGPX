Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "2."}]}], " ", "Count", " ", "event"}], "-", 
    RowBox[{"based", " ", "starts", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", " ", "T", " ", "logic"}], ")"}], "--"}]}], "-"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"countStarts", "[", 
      RowBox[{"times_", ",", "KK_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "times", "]"}]}], "}"}], ",", 
       RowBox[{"Count", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"i", "+", "KK", "-", "1"}], "<=", "n"}], "&&", 
              RowBox[{
               RowBox[{
                RowBox[{"times", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", "+", "KK", "-", "1"}], "]"}], "]"}], "-", 
                RowBox[{"times", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "<=", "t"}]}], ",", "1", ",",
              "0"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
        "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "3."}]}], " ", "Count", " ", "clusters", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"scan", " ", "logic"}], ",", 
         RowBox[{"non", "-", "overlapping"}]}], ")"}], "--"}]}], "-"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"countClusters", "[", 
      RowBox[{"times_", ",", "KK_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"n", "=", 
          RowBox[{"Length", "[", "times", "]"}]}], ",", 
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"count", "=", "0"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"i", "<=", 
           RowBox[{"n", "-", "KK", "+", "1"}]}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"times", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "KK", "-", "1"}], "]"}], "]"}], "-", 
              RowBox[{"times", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "<=", "t"}], ",", 
            RowBox[{"(*", 
             RowBox[{"Found", " ", "a", " ", "cluster"}], "*)"}], 
            RowBox[{
             RowBox[{"count", "++"}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Skip", " ", "all", " ", "events", " ", "belonging", " ", "to", 
               " ", "this", " ", "cluster"}], "*)"}], 
             RowBox[{"(*", 
              RowBox[{
              "Move", " ", "i", " ", "forward", " ", "until", " ", "window", " ",
                "breaks"}], "*)"}], 
             RowBox[{"While", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"i", "<=", 
                 RowBox[{"n", "-", "KK", "+", "1"}]}], "&&", 
                RowBox[{
                 RowBox[{
                  RowBox[{"times", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", "+", "KK", "-", "1"}], "]"}], "]"}], "-", 
                  RowBox[{"times", "[", 
                   RowBox[{"[", "i", "]"}], "]"}]}], "<=", "t"}]}], 
               "\[IndentingNewLine]", ",", 
               RowBox[{"i", "++"}]}], "]"}], ";"}], "\[IndentingNewLine]", ",", 
            RowBox[{"i", "++"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], ";",
         "\[IndentingNewLine]", "count"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "PARAMETERS", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Lambda]", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"KK", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A", "=", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"t", "=", 
     RowBox[{"KK", "/", "A"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "1."}]}], " ", "Simulate", " ", "Poisson", " ", 
      RowBox[{"process", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Simulate", "[", "T_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nEvents", ",", "times"}], "}"}], ",", "\n", 
       RowBox[{
        RowBox[{"nEvents", "=", 
         RowBox[{"RandomVariate", "[", 
          RowBox[{"PoissonDistribution", "[", 
           RowBox[{"\[Lambda]", " ", "T"}], "]"}], "]"}]}], ";", "\n", 
        RowBox[{"times", "=", 
         RowBox[{"Sort", "[", 
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "T"}], "}"}], ",", "nEvents"}], "]"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"countStarts", "[", 
            RowBox[{"times", ",", "KK", ",", "t"}], "]"}], "/", "T"}], ",", 
          "\n", 
          RowBox[{
           RowBox[{"countClusters", "[", 
            RowBox[{"times", ",", "KK", ",", "t"}], "]"}], "/", "T"}]}], 
         "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "5."}]}], " ", 
      RowBox[{"Output", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<\[Lambda] T Alerts (event-based)\>\"", 
      ",", "\"\<ClusterAlerts (scan-based)\>\""}], "}"}], "->", 
    RowBox[{
     RowBox[{"Simulate", "[", "3600", "]"}], "*", "3600"}]}]}]}]], "Input",
