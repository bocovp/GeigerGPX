       RowBox[{"Count", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"i", "+", "KK", "-", "1"}], "<=", "n"}], "&&", 
              RowBox[{
               RowBox[{
                RowBox[{"times", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", "+", "KK", "-", "1"}], "]"}], "]"}], "-", 
                RowBox[{"times", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "<=", "t"}]}], ",", "1", ",",
              "0"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
        "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", " ", 
